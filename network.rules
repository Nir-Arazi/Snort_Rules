# ==========================================
# Author: Nir Arazi
# Description: Network Threat Detection Rules
# Version: 3.0
# Last Updated: 2026
# Categories:
#   01 - DNS Tunneling
#   02 - ICMP Tunneling
#   03 - Port Scanning
#   04 - SMB / EternalBlue
#   05 - File Exfiltration (HTTP/HTTPS/FTP)
#   06 - File Exfiltration (Magic Bytes)
#   07 - File Exfiltration (ICMP)
#   08 - Shell Detection
#   09 - Log4J / Log4Shell
#   10 - Mimikatz (Network-Visible)
#   11 - XSS
#   12 - SQL Injection
#   13 - Ransomware
#   14 - C2 Beaconing
#   15 - Brute Force
#   16 - Reconnaissance
#   17 - Lateral Movement
#   18 - Data Staging
#   19 - Web Attacks (LFI/RFI/CMDi/Traversal/SSRF)
#   20 - Protocol Abuse
#   21 - Malware Specific
#   22 - Cloud / Modern Infrastructure
#   23 - Email Based Attacks
#   24 - VoIP Attacks
#   25 - Industrial / OT
# ==========================================


# ==========================================
# 01 - DNS TUNNELING
# ==========================================

alert udp any any -> any 53 (msg:"DNS TUNNEL Base64 Pattern"; content:"."; depth:1; dsize:>150; sid:1000011; rev:1;)
alert udp any any -> any 53 (msg:"DNS TUNNEL Long Query"; dsize:>100; sid:1000012; rev:1;)
alert udp any any -> any 53 (msg:"DNS TUNNEL Suspicious TXT Record"; content:"|00 10|"; sid:1000013; rev:1;)
alert tcp any any -> any 53 (msg:"DNS TUNNEL TCP Query"; sid:1000014; rev:1;)


# ==========================================
# 02 - ICMP TUNNELING
# ==========================================

alert icmp any any -> any any (msg:"ICMP TUNNEL Large Payload"; dsize:>100; sid:1000015; rev:1;)


# ==========================================
# 03 - PORT SCANNING
# ==========================================

alert tcp any any -> any any (msg:"Possible Port Scan"; flags:S; threshold:type threshold, track by_src, count 20, seconds 3; sid:1000016; rev:1;)


# ==========================================
# 04 - SMB / ETERNALBLUE
# ==========================================

alert tcp any any -> any 445 (msg:"MS17-010 EternalBlue Attempt"; content:"|00 00 00 00 00 57 ff|"; sid:1000017; rev:1;)


# ==========================================
# 05 - FILE EXFILTRATION OVER HTTP/HTTPS/FTP
# ==========================================

alert tcp any any -> any 80 (msg:"FILE EXFIL Large HTTP POST"; content:"POST"; http_method; dsize:>5000; sid:1000020; rev:1;)
alert tcp any any -> any 443 (msg:"FILE EXFIL Large HTTPS Outbound"; dsize:>10000; flow:to_server,established; sid:1000021; rev:1;)
alert tcp any any -> any 21 (msg:"FILE EXFIL FTP Command Channel"; content:"STOR"; sid:1000022; rev:1;)
alert tcp any any -> any 20 (msg:"FILE EXFIL FTP Data Transfer"; dsize:>1000; sid:1000023; rev:1;)


# ==========================================
# 06 - FILE EXFILTRATION BY MAGIC BYTES
# ==========================================

alert tcp any any -> any any (msg:"FILE EXFIL ZIP Archive Detected"; content:"|50 4B 03 04|"; sid:1000024; rev:1;)
alert tcp any any -> any any (msg:"FILE EXFIL PDF Detected"; content:"|25 50 44 46|"; sid:1000025; rev:1;)
alert tcp any any -> any 80 (msg:"FILE EXFIL Base64 in HTTP"; content:"Content-Transfer-Encoding: base64"; sid:1000026; rev:1;)
alert tcp any any -> any 80 (msg:"FILE EXFIL Pastebin Upload"; content:"pastebin.com"; http_header; sid:1000027; rev:1;)


# ==========================================
# 07 - FILE EXFILTRATION OVER ICMP
# ==========================================

alert icmp any any -> any any (msg:"FILE EXFIL ICMP Large Payload"; dsize:>64; itype:8; sid:1000030; rev:1;)
alert icmp any any -> any any (msg:"FILE EXFIL ICMP Oversized Packet"; dsize:>200; sid:1000031; rev:1;)
alert icmp any any -> any any (msg:"FILE EXFIL ICMP ZIP Archive"; content:"|50 4B 03 04|"; itype:8; sid:1000032; rev:1;)
alert icmp any any -> any any (msg:"FILE EXFIL ICMP PDF Detected"; content:"|25 50 44 46|"; itype:8; sid:1000033; rev:1;)
alert icmp any any -> any any (msg:"FILE EXFIL ICMP PNG Detected"; content:"|89 50 4E 47|"; itype:8; sid:1000034; rev:1;)
alert icmp any any -> any any (msg:"FILE EXFIL ICMP High Frequency"; itype:8; threshold:type threshold, track by_src, count 10, seconds 5; sid:1000035; rev:1;)


# ==========================================
# 08 - SHELL DETECTION
# ==========================================

# Netcat
alert tcp any any -> any any (msg:"SHELL Netcat Reverse Shell"; content:"nc -e"; sid:1000040; rev:1;)
alert tcp any any -> any any (msg:"SHELL Netcat Listener"; content:"nc -lvp"; sid:1000041; rev:1;)

# Bash
alert tcp any any -> any any (msg:"SHELL Bash Reverse Shell"; content:"bash -i >& /dev/tcp/"; sid:1000042; rev:1;)

# Python
alert tcp any any -> any any (msg:"SHELL Python Reverse Shell"; content:"python -c"; sid:1000043; rev:1;)
alert tcp any any -> any any (msg:"SHELL Python3 Reverse Shell"; content:"python3 -c"; sid:1000044; rev:1;)

# PowerShell
alert tcp any any -> any any (msg:"SHELL PowerShell Encoded Command"; content:"powershell"; nocase; content:"-enc"; distance:0; sid:1000045; rev:1;)
alert tcp any any -> any any (msg:"SHELL PowerShell Download Cradle"; content:"IEX"; nocase; content:"DownloadString"; nocase; distance:0; sid:1000046; rev:1;)

# Web shells
alert tcp any any -> any 80 (msg:"SHELL Webshell cmd Parameter"; content:"cmd="; http_uri; sid:1000047; rev:1;)
alert tcp any any -> any 80 (msg:"SHELL Webshell exec Parameter"; content:"exec="; http_uri; sid:1000048; rev:1;)
alert tcp any any -> any 80 (msg:"SHELL Webshell passwd Access"; content:"/etc/passwd"; sid:1000049; rev:1;)

# Suspicious ports
alert tcp any any -> any 4444 (msg:"SHELL Suspicious Port 4444 Metasploit Default"; sid:1000050; rev:1;)
alert tcp any any -> any 1337 (msg:"SHELL Suspicious Port 1337"; sid:1000051; rev:1;)
alert tcp any any -> any 9001 (msg:"SHELL Suspicious Port 9001"; sid:1000052; rev:1;)

# Shell binaries in payload
alert tcp any any -> any any (msg:"SHELL bin/sh in Payload"; content:"/bin/sh"; sid:1000053; rev:1;)
alert tcp any any -> any any (msg:"SHELL bin/bash in Payload"; content:"/bin/bash"; sid:1000054; rev:1;)


# ==========================================
# 09 - LOG4J / LOG4SHELL (CVE-2021-44228)
# ==========================================

alert tcp any any -> any any (msg:"LOG4J JNDI Lookup Attempt"; content:"${jndi:"; nocase; sid:1000060; rev:1;)
alert tcp any any -> any any (msg:"LOG4J JNDI LDAP Exploit"; content:"${jndi:ldap://"; nocase; sid:1000061; rev:1;)
alert tcp any any -> any any (msg:"LOG4J JNDI RMI Exploit"; content:"${jndi:rmi://"; nocase; sid:1000062; rev:1;)
alert tcp any any -> any any (msg:"LOG4J JNDI DNS Lookup"; content:"${jndi:dns://"; nocase; sid:1000063; rev:1;)
alert tcp any any -> any any (msg:"LOG4J Obfuscated lower bypass"; content:"${${lower:j}ndi:"; nocase; sid:1000064; rev:1;)
alert tcp any any -> any any (msg:"LOG4J Obfuscated upper bypass"; content:"${${upper:j}ndi:"; nocase; sid:1000065; rev:1;)
alert tcp any any -> any any (msg:"LOG4J Double Nested Bypass"; content:"${${::-j}${::-n}${::-d}${::-i}:"; nocase; sid:1000066; rev:1;)
alert tcp any any -> any 80 (msg:"LOG4J in HTTP User-Agent"; content:"${jndi:"; http_header; nocase; sid:1000067; rev:1;)
alert tcp any any -> any 443 (msg:"LOG4J in HTTPS Header"; content:"${jndi:"; nocase; sid:1000068; rev:1;)
alert tcp any any -> any 389 (msg:"LOG4J Outbound LDAP Callback"; flow:to_server,established; sid:1000069; rev:1;)
alert tcp any any -> any 1389 (msg:"LOG4J Outbound LDAP Alt Port Callback"; flow:to_server,established; sid:1000070; rev:1;)


# ==========================================
# 10 - MIMIKATZ (NETWORK-VISIBLE ONLY)
# ==========================================

alert tcp any any -> any 389 (msg:"MIMIKATZ DCSync LDAP Replication"; content:"DsGetNCChanges"; nocase; sid:1000080; rev:1;)
alert tcp any any -> any 445 (msg:"MIMIKATZ Pass-The-Hash SMB"; content:"NTLMSSP"; nocase; sid:1000081; rev:1;)
alert udp any any -> any 88 (msg:"MIMIKATZ Suspicious Kerberos Large Ticket"; dsize:>1000; sid:1000082; rev:1;)
alert tcp any any -> any 445 (msg:"MIMIKATZ Remote LSASS Dump via SMB"; content:"lsass"; nocase; sid:1000083; rev:1;)


# ==========================================
# 11 - XSS (CROSS-SITE SCRIPTING)
# ==========================================

alert tcp any any -> any 80 (msg:"XSS Script Tag Detected"; content:"<script>"; http_uri; nocase; sid:1000090; rev:1;)
alert tcp any any -> any 80 (msg:"XSS Script Tag in Body"; content:"<script>"; http_client_body; nocase; sid:1000091; rev:1;)
alert tcp any any -> any 80 (msg:"XSS onload Handler"; content:"onload="; http_uri; nocase; sid:1000092; rev:1;)
alert tcp any any -> any 80 (msg:"XSS onerror Handler"; content:"onerror="; http_uri; nocase; sid:1000093; rev:1;)
alert tcp any any -> any 80 (msg:"XSS onclick Handler"; content:"onclick="; http_uri; nocase; sid:1000094; rev:1;)
alert tcp any any -> any 80 (msg:"XSS Javascript URI"; content:"javascript:"; http_uri; nocase; sid:1000095; rev:1;)
alert tcp any any -> any 80 (msg:"XSS URL Encoded Script Tag"; content:"%3Cscript%3E"; http_uri; nocase; sid:1000096; rev:1;)
alert tcp any any -> any 80 (msg:"XSS Unicode Encoded"; content:"\\u003cscript"; http_uri; nocase; sid:1000097; rev:1;)
alert tcp any any -> any 80 (msg:"XSS Document Cookie Access"; content:"document.cookie"; http_uri; nocase; sid:1000098; rev:1;)


# ==========================================
# 12 - SQL INJECTION
# ==========================================

alert tcp any any -> any 80 (msg:"SQLI Union Select"; content:"union select"; http_uri; nocase; sid:1000100; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI OR 1=1"; content:"or 1=1"; http_uri; nocase; sid:1000101; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI AND 1=1"; content:"and 1=1"; http_uri; nocase; sid:1000102; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI Comment Sequence"; content:"--"; http_uri; sid:1000103; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI Hash Comment"; content:"#"; http_uri; sid:1000104; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI Sleep Function"; content:"sleep("; http_uri; nocase; sid:1000105; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI Waitfor Delay"; content:"waitfor delay"; http_uri; nocase; sid:1000106; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI Benchmark Function"; content:"benchmark("; http_uri; nocase; sid:1000107; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI information_schema Access"; content:"information_schema"; http_uri; nocase; sid:1000108; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI sys.tables Access"; content:"sys.tables"; http_uri; nocase; sid:1000109; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI URL Encoded Quote"; content:"%27"; http_uri; sid:1000110; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI URL Encoded Union"; content:"%55nion"; http_uri; nocase; sid:1000111; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI extractvalue Function"; content:"extractvalue("; http_uri; nocase; sid:1000112; rev:1;)
alert tcp any any -> any 80 (msg:"SQLI updatexml Function"; content:"updatexml("; http_uri; nocase; sid:1000113; rev:1;)


# ==========================================
# 13 - RANSOMWARE
# ==========================================

alert tcp any any -> any 445 (msg:"RANSOMWARE SMB Spreading Behavior"; flags:S; threshold:type threshold, track by_src, count 10, seconds 5; sid:1000120; rev:1;)
alert tcp any any -> any 9001 (msg:"RANSOMWARE TOR C2 Port 9001"; sid:1000121; rev:1;)
alert tcp any any -> any 9050 (msg:"RANSOMWARE TOR SOCKS Proxy"; sid:1000122; rev:1;)
alert tcp any any -> any 80 (msg:"RANSOMWARE Encrypted Extension .locked"; content:".locked"; http_uri; nocase; sid:1000123; rev:1;)
alert tcp any any -> any 80 (msg:"RANSOMWARE Encrypted Extension .crypto"; content:".crypto"; http_uri; nocase; sid:1000124; rev:1;)
alert tcp any any -> any 80 (msg:"RANSOMWARE Encrypted Extension .crypt"; content:".crypt"; http_uri; nocase; sid:1000125; rev:1;)
alert tcp any any -> any 80 (msg:"RANSOMWARE Ransom Note Keyword"; content:"YOUR FILES HAVE BEEN ENCRYPTED"; nocase; sid:1000126; rev:1;)
alert tcp any any -> any 80 (msg:"RANSOMWARE Bitcoin Payment Request"; content:"bitcoin"; nocase; content:"wallet"; nocase; distance:0; sid:1000127; rev:1;)


# ==========================================
# 14 - C2 BEACONING
# ==========================================

alert tcp any any -> any 50050 (msg:"C2 Cobalt Strike Default Port"; sid:1000130; rev:1;)
alert tcp any any -> any 8080 (msg:"C2 Suspicious HTTP Alt Port"; sid:1000131; rev:1;)
alert tcp any any -> any 8443 (msg:"C2 Suspicious HTTPS Alt Port"; sid:1000132; rev:1;)
alert tcp any any -> any 80 (msg:"C2 Suspicious Empty User Agent"; content:"User-Agent: |0D 0A|"; http_header; sid:1000133; rev:1;)
alert tcp any any -> any 80 (msg:"C2 Cobalt Strike User Agent"; content:"User-Agent: Mozilla/5.0 (compatible"; http_header; nocase; sid:1000134; rev:1;)
alert tcp any any -> any 80 (msg:"C2 HTTP Beaconing Behavior"; content:"GET"; http_method; threshold:type threshold, track by_src, count 30, seconds 60; sid:1000135; rev:1;)
alert tcp any any -> any 4444 (msg:"C2 Meterpreter Default Port"; sid:1000136; rev:1;)
alert tcp any any -> any 443 (msg:"C2 Meterpreter Reverse HTTPS"; content:"METERPRETER"; nocase; sid:1000137; rev:1;)
alert tcp any any -> any 80 (msg:"C2 PowerShell Empire Beacon"; content:"powershell"; http_client_body; nocase; sid:1000138; rev:1;)

# Sliver C2 framework
alert tcp any any -> any 31337 (msg:"C2 Sliver Framework Default Port"; sid:1000139; rev:1;)

# Havoc C2 framework
alert tcp any any -> any 40056 (msg:"C2 Havoc Framework Default Port"; sid:1000140; rev:1;)

# Known malicious user agents
alert tcp any any -> any 80 (msg:"C2 Suspicious curl User Agent"; content:"User-Agent: curl"; http_header; nocase; sid:1000141; rev:1;)
alert tcp any any -> any 80 (msg:"C2 Python Requests User Agent"; content:"python-requests"; http_header; nocase; sid:1000142; rev:1;)
alert tcp any any -> any 80 (msg:"C2 Go HTTP User Agent"; content:"Go-http-client"; http_header; nocase; sid:1000143; rev:1;)


# ==========================================
# 15 - BRUTE FORCE
# ==========================================

alert tcp any any -> any 22 (msg:"BRUTE FORCE SSH Login Attempt"; content:"SSH"; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000150; rev:1;)
alert tcp any any -> any 3389 (msg:"BRUTE FORCE RDP Login Attempt"; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000151; rev:1;)
alert tcp any any -> any 80 (msg:"BRUTE FORCE HTTP POST Login"; content:"POST"; http_method; content:"password"; http_client_body; nocase; threshold:type threshold, track by_src, count 10, seconds 30; sid:1000152; rev:1;)
alert tcp any any -> any 21 (msg:"BRUTE FORCE FTP Login Attempt"; content:"USER"; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000153; rev:1;)
alert tcp any any -> any 445 (msg:"BRUTE FORCE SMB Authentication"; content:"NTLMSSP"; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000154; rev:1;)
alert tcp any any -> any 23 (msg:"BRUTE FORCE Telnet Attempt"; threshold:type threshold, track by_src, count 5, seconds 60; sid:1000155; rev:1;)


# ==========================================
# 16 - RECONNAISSANCE
# ==========================================

# NMAP scan types
alert tcp any any -> any any (msg:"RECON NMAP OS Fingerprint"; flags:SF; sid:1000160; rev:1;)
alert tcp any any -> any any (msg:"RECON NMAP NULL Scan"; flags:0; sid:1000161; rev:1;)
alert tcp any any -> any any (msg:"RECON NMAP FIN Scan"; flags:F; sid:1000162; rev:1;)
alert tcp any any -> any any (msg:"RECON NMAP XMAS Scan"; flags:FPU; sid:1000163; rev:1;)

# SMB enumeration
alert tcp any any -> any 445 (msg:"RECON SMB Enumeration"; content:"SAMR"; nocase; sid:1000164; rev:1;)
alert tcp any any -> any 445 (msg:"RECON SMB Share Enumeration"; content:"srvsvc"; nocase; sid:1000165; rev:1;)

# LDAP enumeration
alert tcp any any -> any 389 (msg:"RECON LDAP Enumeration"; content:"objectClass"; nocase; sid:1000166; rev:1;)
alert tcp any any -> any 389 (msg:"RECON LDAP User Enumeration"; content:"samAccountName"; nocase; sid:1000167; rev:1;)

# DNS zone transfer
alert tcp any any -> any 53 (msg:"RECON DNS Zone Transfer AXFR"; content:"|00 FC|"; sid:1000168; rev:1;)
alert udp any any -> any 53 (msg:"RECON DNS ANY Record Request"; content:"|00 FF|"; sid:1000169; rev:1;)

# SNMP enumeration
alert udp any any -> any 161 (msg:"RECON SNMP Enumeration"; content:"public"; sid:1000170; rev:1;)


# ==========================================
# 17 - LATERAL MOVEMENT
# ==========================================

alert tcp any any -> any 445 (msg:"LATERAL MOVEMENT PsExec Detected"; content:"PSEXESVC"; nocase; sid:1000180; rev:1;)
alert tcp any any -> any 445 (msg:"LATERAL MOVEMENT PsExec Binary"; content:"|50 53 45 58 45 53 56 43|"; sid:1000181; rev:1;)
alert tcp any any -> any 135 (msg:"LATERAL MOVEMENT WMI Remote Execution"; content:"IWbemServices"; nocase; sid:1000182; rev:1;)
alert tcp any any -> any 135 (msg:"LATERAL MOVEMENT DCOM Activation"; sid:1000183; rev:1;)
alert tcp any any -> any 3389 (msg:"LATERAL MOVEMENT RDP Connection"; sid:1000184; rev:1;)
alert tcp any any -> any 445 (msg:"LATERAL MOVEMENT Admin Share C$"; content:"C$"; sid:1000185; rev:1;)
alert tcp any any -> any 445 (msg:"LATERAL MOVEMENT Admin Share ADMIN$"; content:"ADMIN$"; sid:1000186; rev:1;)
alert tcp any any -> any 445 (msg:"LATERAL MOVEMENT IPC$ Access"; content:"IPC$"; sid:1000187; rev:1;)
alert udp any any -> any 88 (msg:"LATERAL MOVEMENT Kerberos Pass The Ticket"; dsize:>1500; sid:1000188; rev:1;)
alert tcp any any -> any 445 (msg:"LATERAL MOVEMENT Remote Service Creation"; content:"svcctl"; nocase; sid:1000189; rev:1;)


# ==========================================
# 18 - DATA STAGING
# ==========================================

alert tcp any any -> any any (msg:"DATA STAGING RAR Archive Detected"; content:"|52 61 72 21 1A 07|"; sid:1000190; rev:1;)
alert tcp any any -> any any (msg:"DATA STAGING 7ZIP Archive Detected"; content:"|37 7A BC AF 27 1C|"; sid:1000191; rev:1;)
alert tcp any any -> any any (msg:"DATA STAGING GZIP Archive Detected"; content:"|1F 8B 08|"; sid:1000192; rev:1;)
alert tcp any any -> any 445 (msg:"DATA STAGING Large SMB Transfer"; dsize:>50000; sid:1000193; rev:1;)
alert tcp any any -> any 80 (msg:"DATA STAGING Temp Directory Upload"; content:"/temp/"; http_uri; nocase; sid:1000194; rev:1;)
alert tcp any any -> any 80 (msg:"DATA STAGING AppData Upload"; content:"AppData"; http_uri; nocase; sid:1000195; rev:1;)
alert tcp any any -> any 80 (msg:"DATA STAGING Password Protected Archive"; content:"password"; http_client_body; nocase; content:".zip"; http_client_body; nocase; distance:0; sid:1000196; rev:1;)


# ==========================================
# 19 - WEB ATTACKS (LFI/RFI/CMDi/Traversal/SSRF)
# ==========================================

# Local File Inclusion (LFI)
alert tcp any any -> any 80 (msg:"WEB ATTACK LFI /etc/passwd"; content:"/etc/passwd"; http_uri; nocase; sid:1000200; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK LFI /etc/shadow"; content:"/etc/shadow"; http_uri; nocase; sid:1000201; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK LFI Windows SAM"; content:"win.ini"; http_uri; nocase; sid:1000202; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK LFI proc/self"; content:"proc/self"; http_uri; nocase; sid:1000203; rev:1;)

# Path Traversal
alert tcp any any -> any 80 (msg:"WEB ATTACK Path Traversal ../"; content:"../"; http_uri; sid:1000204; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK Path Traversal Encoded %2e%2e"; content:"%2e%2e%2f"; http_uri; nocase; sid:1000205; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK Path Traversal Double Encoded"; content:"..%2f"; http_uri; nocase; sid:1000206; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK Path Traversal Windows"; content:"..\\"; http_uri; sid:1000207; rev:1;)

# Remote File Inclusion (RFI)
alert tcp any any -> any 80 (msg:"WEB ATTACK RFI HTTP Include"; content:"=http://"; http_uri; nocase; sid:1000208; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK RFI FTP Include"; content:"=ftp://"; http_uri; nocase; sid:1000209; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK RFI PHP Wrapper"; content:"php://input"; http_uri; nocase; sid:1000210; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK RFI Data URI"; content:"data://"; http_uri; nocase; sid:1000211; rev:1;)

# Command Injection
alert tcp any any -> any 80 (msg:"WEB ATTACK CMDi Semicolon Injection"; content:";whoami"; http_uri; nocase; sid:1000212; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK CMDi Pipe Injection"; content:"|id"; http_uri; nocase; sid:1000213; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK CMDi AND Injection"; content:"&&cat"; http_uri; nocase; sid:1000214; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK CMDi Backtick Injection"; content:"`id`"; http_uri; nocase; sid:1000215; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK CMDi wget"; content:"wget "; http_uri; nocase; sid:1000216; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK CMDi curl"; content:"curl "; http_uri; nocase; sid:1000217; rev:1;)

# SSRF (Server Side Request Forgery)
alert tcp any any -> any 80 (msg:"WEB ATTACK SSRF AWS Metadata"; content:"169.254.169.254"; http_uri; sid:1000218; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK SSRF Localhost"; content:"localhost"; http_uri; nocase; sid:1000219; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK SSRF 127.0.0.1"; content:"127.0.0.1"; http_uri; sid:1000220; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK SSRF Internal Range 192.168"; content:"192.168."; http_uri; sid:1000221; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK SSRF Internal Range 10.0"; content:"10.0."; http_uri; sid:1000222; rev:1;)

# XXE (XML External Entity)
alert tcp any any -> any 80 (msg:"WEB ATTACK XXE DOCTYPE Declaration"; content:"<!DOCTYPE"; http_client_body; nocase; sid:1000223; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK XXE ENTITY Declaration"; content:"<!ENTITY"; http_client_body; nocase; sid:1000224; rev:1;)
alert tcp any any -> any 80 (msg:"WEB ATTACK XXE SYSTEM Keyword"; content:"SYSTEM"; http_client_body; nocase; content:"file://"; http_client_body; nocase; distance:0; sid:1000225; rev:1;)


# ==========================================
# 20 - PROTOCOL ABUSE
# ==========================================

# HTTP CONNECT tunneling
alert tcp any any -> any 80 (msg:"PROTOCOL ABUSE HTTP CONNECT Tunnel"; content:"CONNECT "; depth:8; sid:1000230; rev:1;)
alert tcp any any -> any 8080 (msg:"PROTOCOL ABUSE HTTP CONNECT Alt Port"; content:"CONNECT "; depth:8; sid:1000231; rev:1;)

# SSL/TLS on non-standard ports
alert tcp any any -> any 4444 (msg:"PROTOCOL ABUSE SSL on Non-Standard Port 4444"; content:"|16 03|"; sid:1000232; rev:1;)
alert tcp any any -> any 8888 (msg:"PROTOCOL ABUSE SSL on Non-Standard Port 8888"; content:"|16 03|"; sid:1000233; rev:1;)
alert tcp any any -> any 1234 (msg:"PROTOCOL ABUSE SSL on Non-Standard Port 1234"; content:"|16 03|"; sid:1000234; rev:1;)

# IPv6 tunneling over IPv4
alert ip any any -> any any (msg:"PROTOCOL ABUSE IPv6 in IPv4 Tunnel"; ip_proto:41; sid:1000235; rev:1;)

# DNS over HTTP (DoH abuse for C2)
alert tcp any any -> any 443 (msg:"PROTOCOL ABUSE DNS over HTTPS"; content:"dns-query"; http_uri; nocase; sid:1000236; rev:1;)

# ICMP redirect abuse
alert icmp any any -> any any (msg:"PROTOCOL ABUSE ICMP Redirect"; itype:5; sid:1000237; rev:1;)

# Unusual protocol on common ports
alert tcp any any -> any 80 (msg:"PROTOCOL ABUSE Non-HTTP on Port 80"; content:"|16 03|"; sid:1000238; rev:1;)


# ==========================================
# 21 - MALWARE SPECIFIC
# ==========================================

# Emotet C2 patterns
